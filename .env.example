# ─── Data Paths ────────────────────────────────────────────────────────────────
DATA_PATH=data/historical_lending.parquet
OUTPUT_DIR=models/artifacts/

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/underwriting

# ─── S3-Compatible Storage ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=underwriting-artifacts
S3_ENDPOINT_URL=https://s3.amazonaws.com

# ─── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=ai-underwriting-phase1

# ─── Triton Inference Server ────────────────────────────────────────────────────
TRITON_URL=localhost:8000
TRITON_GRPC_URL=localhost:8001

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
